# Repro Web SDK
NEXT_PUBLIC_REPRO_TOKEN=your_repro_sdk_token_here

# Upstash Redis（オプション。未設定の場合はメモリストアを使用）
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# iron-session暗号化キー（32文字以上のランダム文字列）
SESSION_SECRET=change_this_to_a_random_32_char_secret
